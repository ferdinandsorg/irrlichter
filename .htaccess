# Irrlichter — Kurz-URLs + Legacy-Redirects (Apache)
# Seiten liegen in Ordnern: /mitmachen/index.html usw. (funktioniert auch ohne Rewrite)
# Lokal: python3 scripts/dev-server.py  oder  python3 -m http.server

Options -MultiViews
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Legacy-Pfade
  RewriteRule ^events/?$ /mitmachen [R=301,L]
  RewriteRule ^info/?$ /das-projekt [R=301,L]
  RewriteRule ^anfahrt/?$ /das-projekt#kontakt-anfahrt [R=301,L,NE]

  # Alte Root-Dateien *.html → Ordner-URLs (falls noch angefragt)
  RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
  RewriteRule ^ / [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+mitmachen\.html[\s?] [NC]
  RewriteRule ^ /mitmachen [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+das-projekt\.html[\s?] [NC]
  RewriteRule ^ /das-projekt [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+impressum\.html[\s?] [NC]
  RewriteRule ^ /impressum [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+datenschutz\.html[\s?] [NC]
  RewriteRule ^ /datenschutz [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+admin\.html[\s?] [NC]
  RewriteRule ^ /admin [R=301,L]

  # Sonstige *.html im Root (nur falls noch vorhanden)
  RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]
</IfModule>
