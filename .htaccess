# Irrlichter — Kurz-URLs + Legacy-Redirects (Apache)
# Seiten: /veranstaltungen/index.html, /ueber/index.html (auch ohne Rewrite)
# Lokal: python3 scripts/dev-server.py  oder  python3 -m http.server

Options -MultiViews
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Umbenannte Seiten (301)
  RewriteRule ^mitmachen/?$ /veranstaltungen [R=301,L]
  RewriteRule ^das-projekt/?$ /ueber [R=301,L]

  # Legacy-Pfade
  RewriteRule ^events/?$ /veranstaltungen [R=301,L]
  RewriteRule ^info/?$ /ueber [R=301,L]
  RewriteRule ^anfahrt/?$ /ueber#anfahrt [R=301,L,NE]

  # Alte Root-Dateien *.html → aktuelle Ordner-URLs
  RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
  RewriteRule ^ / [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+mitmachen\.html[\s?] [NC]
  RewriteRule ^ /veranstaltungen [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+das-projekt\.html[\s?] [NC]
  RewriteRule ^ /ueber [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+impressum\.html[\s?] [NC]
  RewriteRule ^ /impressum [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+datenschutz\.html[\s?] [NC]
  RewriteRule ^ /datenschutz [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+admin\.html[\s?] [NC]
  RewriteRule ^ /admin [R=301,L]

  # Sonstige *.html im Root (nur falls noch vorhanden)
  RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]
</IfModule>
