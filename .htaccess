# Irrlichter — „schöne“ URLs ohne .html (Apache, mod_rewrite)
# Beispiel: /mitmachen und /mitmachen.html liefern beides die Datei mitmachen.html (interner Rewrite).
# Voraussetzung: AllowOverride FileInfo (oder All) fuer dieses Verzeichnis.

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Alte URLs → neue Seiten
  RewriteRule ^events\.html$ mitmachen.html [R=301,L]
  RewriteRule ^events/?$ mitmachen.html [R=301,L]
  RewriteRule ^info\.html$ das-projekt.html [R=301,L]
  RewriteRule ^info/?$ das-projekt.html [R=301,L]
  RewriteRule ^anfahrt\.html$ das-projekt.html#kontakt-anfahrt [R=301,L,NE]
  RewriteRule ^anfahrt/?$ das-projekt.html#kontakt-anfahrt [R=301,L,NE]

  # Bereits existierende Datei oder Verzeichnis nicht anfassen
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Nur wenn zugehoerige *.html existiert: intern auf diese Datei umbiegen
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ $1.html [L,QSA]
</IfModule>

# Optional: weitere Kurz-URLs (Beispiel):
# RewriteRule ^veranstaltungen/?$ mitmachen.html [L]
