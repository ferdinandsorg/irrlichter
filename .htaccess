# Irrlichter — Kurz-URLs + Legacy-Redirects (Apache)
# Seiten: /veranstaltungen/index.html, /ueber/index.html (auch ohne Rewrite)
# Lokal: python3 scripts/dev-server.py  oder  python3 -m http.server

Options -MultiViews
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # HTTP → HTTPS (Zertifikat irrlichter.net aktiv; zusätzlich ggf. Server-Redirect in KonsoleH)
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # Umbenannte Seiten (301) — relative Ziele (funktioniert in /beta/ und am Root)
  RewriteRule ^mitmachen/?$ veranstaltungen [R=301,L]
  RewriteRule ^das-projekt/?$ ueber [R=301,L]

  # Legacy-Pfade
  RewriteRule ^events/?$ veranstaltungen [R=301,L]
  RewriteRule ^info/?$ ueber [R=301,L]
  RewriteRule ^anfahrt/?$ ueber#anfahrt [R=301,L,NE]

  # Alte *.html → Ordner-URLs (relativ zum aktuellen Verzeichnis)
  RewriteCond %{THE_REQUEST} \s[^\s]*/index\.html[\s?] [NC]
  RewriteRule ^index\.html$ ./ [R=301,L]

  RewriteCond %{THE_REQUEST} \s[^\s]*/mitmachen\.html[\s?] [NC]
  RewriteRule ^mitmachen\.html$ veranstaltungen [R=301,L]

  RewriteCond %{THE_REQUEST} \s[^\s]*/das-projekt\.html[\s?] [NC]
  RewriteRule ^das-projekt\.html$ ueber [R=301,L]

  RewriteCond %{THE_REQUEST} \s[^\s]*/impressum\.html[\s?] [NC]
  RewriteRule ^impressum\.html$ impressum [R=301,L]

  RewriteCond %{THE_REQUEST} \s[^\s]*/datenschutz\.html[\s?] [NC]
  RewriteRule ^datenschutz\.html$ datenschutz [R=301,L]

  RewriteCond %{THE_REQUEST} \s[^\s]*/admin(?:\.html)?[\s?] [NC]
  RewriteRule ^admin(?:\.html)?$ ./ [R=301,L]

  RewriteCond %{THE_REQUEST} \s[^\s]*/([^/\s]+)\.html[\s?] [NC]
  RewriteRule ^([^/]+)\.html$ $1 [R=301,L]
</IfModule>
