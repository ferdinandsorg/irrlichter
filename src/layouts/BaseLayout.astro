---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  lang: "de" | "en";
  currentPath: string;
}

const { title, description, lang, currentPath } = Astro.props;

const labels = {
  de: {
    home: "Start",
    info: "Info",
    events: "Events",
    skip: "Zum Inhalt springen"
  },
  en: {
    home: "Home",
    info: "Info",
    events: "Events",
    skip: "Skip to content"
  }
};

const nav = [
  { href: `/${lang}/`, label: labels[lang].home },
  { href: `/${lang}/info`, label: labels[lang].info },
  { href: `/${lang}/events`, label: labels[lang].events }
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <a class="skip-link" href="#content">{labels[lang].skip}</a>
    <header class="site-header">
      <div class="inner main-nav">
        <a class="brand" href={`/${lang}/`}>Irrlichter</a>
        <nav class="nav-links" aria-label="Main">
          {
            nav.map((item) => (
              <a href={item.href} aria-current={currentPath === item.href ? "page" : undefined}>
                {item.label}
              </a>
            ))
          }
        </nav>
        <nav class="lang-links" aria-label="Language">
          <a href="/de/" aria-current={lang === "de" ? "page" : undefined}>DE</a>
          <span aria-hidden="true">/</span>
          <a href="/en/" aria-current={lang === "en" ? "page" : undefined}>EN</a>
        </nav>
      </div>
    </header>
    <main id="content">
      <div class="inner">
        <slot />
      </div>
    </main>
    <footer class="site-footer">
      <div class="inner">
        <small>Projekt Irrlichter · moorbasiertes Kunst- und Umweltarchiv</small>
      </div>
    </footer>
  </body>
</html>
