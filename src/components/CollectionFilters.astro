---
interface Props {
  types: string[];
  tags: string[];
  lang: "de" | "en";
}

const { types, tags, lang } = Astro.props;

const text = {
  de: {
    type: "Medientyp",
    tag: "Tag",
    allTypes: "Alle Typen",
    allTags: "Alle Tags"
  },
  en: {
    type: "Media type",
    tag: "Tag",
    allTypes: "All types",
    allTags: "All tags"
  }
};
---

<form class="collection-controls" aria-label="Collection filters">
  <label for="filter-type">
    {text[lang].type}
    <select id="filter-type" data-filter-type>
      <option value="all">{text[lang].allTypes}</option>
      {types.map((type) => <option value={type}>{type}</option>)}
    </select>
  </label>
  <label for="filter-tag">
    {text[lang].tag}
    <select id="filter-tag" data-filter-tag>
      <option value="all">{text[lang].allTags}</option>
      {tags.map((tag) => <option value={tag}>{tag}</option>)}
    </select>
  </label>
</form>
