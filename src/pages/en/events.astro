---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EventList from "../../components/EventList.astro";
import events from "../../data/events.json";
---

<BaseLayout
  title="Irrlichter | Events"
  description="Simple event list for the Irrlichter project."
  lang="en"
  currentPath="/en/events"
>
  <section class="hero">
    <h1>Events</h1>
    <p>Upcoming dates and small formats around the project.</p>
  </section>
  <EventList events={events} lang="en" />
</BaseLayout>
