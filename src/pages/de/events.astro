---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EventList from "../../components/EventList.astro";
import events from "../../data/events.json";
---

<BaseLayout
  title="Irrlichter | Events"
  description="Einfache Eventliste des Irrlichter Projekts."
  lang="de"
  currentPath="/de/events"
>
  <section class="hero">
    <h1>Events</h1>
    <p>Kommende Termine und kleine Formate rund um das Projekt.</p>
  </section>
  <EventList events={events} lang="de" />
</BaseLayout>
