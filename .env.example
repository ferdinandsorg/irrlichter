# Copy to .env and fill in (never commit .env).
#
# Staging (beta):
#   bash scripts/deploy-ftp-beta.sh
#   → https://irrlichter.net/beta/
#
# Production (document root):
#   bash scripts/deploy-ftp-production.sh
#   → https://irrlichter.net/
#
FTP_HOST=b3lk.your-vhost.de
FTP_USER=your-ftp-user
FTP_PASSWORD=your-ftp-password

# Hetzner: FTP-Login liegt oft schon in public_html.
# Staging:  FTP_REMOTE_DIR=beta
# Production: FTP_REMOTE_DIR=.
FTP_REMOTE_DIR=beta
